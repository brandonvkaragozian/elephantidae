<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Walayar Elephant Hotspot Camera Placement</name>
  <description>16 Cameras Optimized for Elephant Collision/Congregation Zones</description>
  
  <Style id="cameraIcon">
    <IconStyle>
      <Icon><href>http://maps.google.com/mapfiles/kml/shapes/camera.png</href></Icon>
      <scale>1.2</scale>
    </IconStyle>
    <LabelStyle><scale>1.0</scale></LabelStyle>
  </Style>
  
  <Style id="detectionZone">
    <PolyStyle><fill>1</fill><outline>1</outline><color>7700FF00</color></PolyStyle>
    <LineStyle><color>FF00FF00</color><width>2</width></LineStyle>
  </Style>
  
  <Style id="tier1Hotspot">
    <PolyStyle><fill>1</fill><outline>1</outline><color>66FF0000</color></PolyStyle>
    <LineStyle><color>FFFF0000</color><width>1</width></LineStyle>
  </Style>
  
  <Style id="tier2Hotspot">
    <PolyStyle><fill>1</fill><outline>1</outline><color>66FFAA00</color></PolyStyle>
    <LineStyle><color>FFFFAA00</color><width>1</width></LineStyle>
  </Style>
  
  <Folder>
    <name>Hotspot Zones (Elephant Congregation Areas)</name>
    <description>Red = TIER 1 (Critical, 8+ visits) | Orange = TIER 2 (High, 3-8 visits)</description>

